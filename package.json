{
  "name": "gemini-ai-lib",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "build2": "tsc -p tsconfig.json",
    "dev2": "tsc -p tsconfig.json --watch",
    "prettyfy": "prettier --write \"src/**/*.{js,jsx,mjs,cjs,ts,tsx,json}\""
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "consola": "^3.4.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}