{
  "name": "@villutur/gemini-ai-lib",
  "version": "0.5.1",
  "private": false,
  "description": "Reusable TypeScript wrappers and helpers for Google's Gemini API.",
  "author": "Villu Tur",
  "license": "MIT",
  "keywords": [
    "gemini",
    "google-genai",
    "ai",
    "typescript",
    "sdk",
    "multimodal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/villutur/gemini-ai-lib.git"
  },
  "bugs": {
    "url": "https://github.com/villutur/gemini-ai-lib/issues"
  },
  "homepage": "https://github.com/villutur/gemini-ai-lib#readme",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./model-catalogs": {
      "types": "./dist/model-catalogs.d.ts",
      "import": "./dist/model-catalogs.js",
      "require": "./dist/model-catalogs.cjs",
      "default": "./dist/model-catalogs.js"
    },
    "./model-capabilities": {
      "types": "./dist/model-capabilities.d.ts",
      "import": "./dist/model-capabilities.js",
      "require": "./dist/model-capabilities.cjs",
      "default": "./dist/model-capabilities.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "build2": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "release:bump": "node ./scripts/release-bump.mjs",
    "release:pack": "npm pack --dry-run",
    "release:publish": "npm publish --access public",
    "dev2": "tsc -p tsconfig.json --watch",
    "prettyfy": "prettier --write \"src/**/*.{js,jsx,mjs,cjs,ts,tsx,json}\""
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "consola": "^3.4.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
